DATABASE_URL=
DATABASE_SSL=false
DB_USER=postgres
DB_HOST=localhost
DB_NAME=gestionDeportiva
DB_PASSWORD=tu_password
DB_PORT=5432

# Almacenamiento de archivos
# Local: dejar vacío para usar backend/uploads
# Render con disco persistente: /var/data/uploads
UPLOADS_DIR=

JWT_SECRET=sgd-dev-secret-change-me
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=
AUTH_ADMIN_NOMBRE=Administrador SGD
CORS_ORIGINS=*

# URL base del frontend (se usa en emails de bienvenida y links de login)
# Local con Live Server: http://127.0.0.1:5500/frontend
# Render mismo servicio: https://tu-servicio.onrender.com/frontend
FRONTEND_URL=http://127.0.0.1:5500/frontend

# URL del frontend para el enlace de recuperación
# Local con Live Server: http://127.0.0.1:5500/frontend/login.html
# Render mismo servicio: https://tu-servicio.onrender.com/login.html
FRONTEND_RESET_URL=http://127.0.0.1:5500/frontend/login.html

# SMTP para emails del sistema (bienvenida, contacto, recuperación de contraseña)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_IGNORE_TLS=false
MAIL_FROM=

# Email del administrador del sistema (recibe alertas de nuevos registros y contacto)
# Si se omite, se usa SMTP_USER como destino
ADMIN_EMAIL=
